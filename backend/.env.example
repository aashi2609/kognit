# ===== Kognit Backend Environment =====

# --- Database ---
DATABASE_URL=postgresql+asyncpg://kognit:kognit_secret@localhost:5432/kognit_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Code Executor ---
# Options: "subprocess" (local compilers) or "piston" (cloud API)
EXECUTOR_BACKEND=piston

# --- LLM (via LiteLLM — swap freely) ---
# Fast tier (confusion classifier, tagger)
LLM_MODEL_FAST=gemini/gemini-2.0-flash
# Strong tier (Socratic agent)
LLM_MODEL_STRONG=gemini/gemini-2.0-flash

# Provider API keys (set whichever provider you use)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Transcription ---
# Options: "local" (faster-whisper CPU) or "deepgram" or "google"
STT_BACKEND=local
WHISPER_MODEL_SIZE=base.en
DEEPGRAM_API_KEY=

# --- Auth ---
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Server ---
BACKEND_CORS_ORIGINS=http://localhost:3000
