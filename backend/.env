# ===== Kognit Backend Environment =====

# --- Database ---
DATABASE_URL=postgresql+asyncpg://kognit:kognit_secret@localhost:5432/kognit_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Code Executor ---
EXECUTOR_BACKEND=piston

# --- LLM (via LiteLLM) ---
LLM_MODEL_FAST=gemini/gemini-2.0-flash
LLM_MODEL_STRONG=gemini/gemini-2.0-flash
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Transcription ---
STT_BACKEND=local
WHISPER_MODEL_SIZE=base.en
DEEPGRAM_API_KEY=

# --- Auth ---
JWT_SECRET_KEY=dev-only-change-me-in-production-please
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Server ---
BACKEND_CORS_ORIGINS=http://localhost:3000
